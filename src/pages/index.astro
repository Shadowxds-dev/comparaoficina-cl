---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";
import Newsletter from "../components/Newsletter.tsx";
import { products, PRODUCT_TYPE_LABELS } from "../data/products";
import type { ProductType } from "../types";

const categories: { type: ProductType; href: string; blurb: string }[] = [
  { type: "silla", href: "/sillas/", blurb: "Soporte lumbar, reclinación y capacidad de peso" },
  { type: "escritorio", href: "/escritorios/", blurb: "Fijos, elevables y gamer en L" },
  { type: "monitor", href: "/monitores/", blurb: "Productividad, diseño y gaming" },
  { type: "accesorio", href: "/accesorios/", blurb: "Brazos de monitor, teclados y más" },
];

const featured = [...products].sort((a, b) => b.reviewCount - a.reviewCount).slice(0, 6);
---

<Layout
  title="Sillas, Escritorios, Monitores y Accesorios de Oficina en Chile"
  description="Comparativas independientes de sillas ergonómicas, escritorios, monitores y accesorios de oficina disponibles en Mercado Libre Chile. Fichas técnicas, comparador y precios en CLP."
>
  <main class="mx-auto max-w-6xl px-4 pb-16">
    <section class="mt-8 rounded-3xl bg-gradient-to-br from-brand-600 to-brand-900 px-8 py-14 text-white sm:mt-12">
      <p class="text-sm font-semibold uppercase tracking-wide text-brand-200">Guía comparativa independiente</p>
      <h1 class="mt-3 max-w-2xl text-3xl font-bold sm:text-4xl">
        Arma tu oficina o setup ideal: sillas, escritorios, monitores y accesorios
      </h1>
      <p class="mt-4 max-w-xl text-brand-100">
        Comparamos {products.length} productos disponibles en Mercado Libre Chile por ficha técnica, precio y
        valoraciones para que decidas en minutos, no en semanas.
      </p>
      <a
        href="/comparador/"
        class="mt-6 inline-block rounded-lg bg-white px-5 py-2.5 text-sm font-semibold text-brand-700 transition hover:bg-brand-50"
      >
        Abrir el comparador →
      </a>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-bold text-ink-900">Explora por categoría</h2>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          categories.map((c) => (
            <a
              href={c.href}
              class="rounded-2xl border border-ink-100 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
            >
              <div class="text-lg font-bold text-ink-900">{PRODUCT_TYPE_LABELS[c.type]}</div>
              <p class="mt-1 text-sm text-ink-500">{c.blurb}</p>
              <span class="mt-3 inline-block text-sm font-semibold text-brand-600">Ver comparativa →</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-bold text-ink-900">Los más valorados</h2>
      <div class="mt-4 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map((product) => <ProductCard product={product} />)}
      </div>
    </section>

    <div class="mt-14">
      <Newsletter client:visible />
    </div>
  </main>
</Layout>
