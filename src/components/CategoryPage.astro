---
import Layout from "../layouts/Layout.astro";
import ProductGrid from "./ProductGrid.tsx";
import type { Product, ProductType } from "../types";
import { SITE_URL, SITE_NAME } from "../consts";

interface Faq {
  q: string;
  a: string;
}

interface Props {
  type: ProductType;
  title: string;
  metaDescription: string;
  h1: string;
  intro: string[];
  faqs: Faq[];
  products: Product[];
  path: string;
}

const { title, metaDescription, h1, intro, faqs, products, path } = Astro.props;

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: SITE_URL },
    { "@type": "ListItem", position: 2, name: h1, item: `${SITE_URL}${path}` },
  ],
};

const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: products.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `${SITE_URL}/producto/${p.slug}/`,
    name: `${p.brand} ${p.name}`,
  })),
};

const faqJsonLd = faqs.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faqs.map((f) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: { "@type": "Answer", text: f.a },
      })),
    }
  : null;

const jsonLd = [breadcrumbJsonLd, itemListJsonLd, ...(faqJsonLd ? [faqJsonLd] : [])];
---

<Layout title={title} description={metaDescription} jsonLd={jsonLd}>
  <main class="mx-auto max-w-6xl px-4 pb-16">
    <nav class="my-6 text-sm text-ink-400" aria-label="Breadcrumb">
      <a href="/" class="hover:text-brand-600">Inicio</a> / <span class="text-ink-600">{h1}</span>
    </nav>

    <h1 class="text-3xl font-bold text-ink-900">{h1}</h1>
    <div class="mt-4 max-w-3xl space-y-3 text-ink-600">
      {intro.map((p) => <p>{p}</p>)}
    </div>

    <div class="mt-8">
      <ProductGrid products={products} client:load />
    </div>

    {
      faqs.length > 0 && (
        <section class="mt-14 max-w-3xl">
          <h2 class="text-xl font-bold text-ink-900">Preguntas frecuentes</h2>
          <div class="mt-4 space-y-4">
            {faqs.map((f) => (
              <div class="rounded-xl border border-ink-100 bg-white p-4">
                <h3 class="font-semibold text-ink-900">{f.q}</h3>
                <p class="mt-1.5 text-sm text-ink-600">{f.a}</p>
              </div>
            ))}
          </div>
        </section>
      )
    }
  </main>
</Layout>
