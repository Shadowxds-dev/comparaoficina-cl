---
interface Props {
  rating: number;
  reviewCount?: number;
  size?: "sm" | "md";
}

const { rating, reviewCount, size = "sm" } = Astro.props;
const starSize = size === "sm" ? "h-3.5 w-3.5" : "h-5 w-5";
const stars = Array.from({ length: 5 }, (_, i) => Math.min(1, Math.max(0, rating - i)));
---

<div class="flex items-center gap-1.5">
  <div class="flex">
    {
      stars.map((fill) => (
        <div class:list={["relative", starSize]}>
          <svg viewBox="0 0 20 20" class:list={[starSize, "text-ink-200"]} fill="currentColor">
            <path d="M10 1.5l2.6 5.6 6.1.6-4.6 4.1 1.3 6-5.4-3.1-5.4 3.1 1.3-6L1.3 7.7l6.1-.6L10 1.5Z" />
          </svg>
          <div class="absolute inset-0 overflow-hidden" style={`width: ${fill * 100}%`}>
            <svg viewBox="0 0 20 20" class:list={[starSize, "text-amber-400"]} fill="currentColor">
              <path d="M10 1.5l2.6 5.6 6.1.6-4.6 4.1 1.3 6-5.4-3.1-5.4 3.1 1.3-6L1.3 7.7l6.1-.6L10 1.5Z" />
            </svg>
          </div>
        </div>
      ))
    }
  </div>
  <span class="text-sm font-medium text-ink-700">{rating.toFixed(1)}</span>
  {reviewCount !== undefined && <span class="text-xs text-ink-400">({reviewCount.toLocaleString("es-CL")})</span>}
</div>
