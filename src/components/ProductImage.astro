---
import type { ProductTier, ProductType } from "../types";
import { TIER_LABELS } from "../data/products";

interface Props {
  type: ProductType;
  tier: ProductTier;
  image?: string;
  class?: string;
  title: string;
}

const { type, tier, image, class: className = "", title } = Astro.props;

const GRADIENTS: Record<ProductTier, string> = {
  economica: "from-emerald-400 to-teal-600",
  media: "from-brand-400 to-brand-700",
  premium: "from-ink-700 to-ink-900",
  gaming: "from-fuchsia-500 to-purple-800",
};

const PATHS: Record<ProductType, string> = {
  silla: "M20 8h24l-2 20H22L20 8Z M22 28l-4 20M42 28l4 20 M18 48h28 M18 48l-3 10M46 48l3 10",
  escritorio: "M8 24h48 M8 24v4 M56 24v4 M14 28v20 M50 28v20 M8 24l4-10h40l4 10",
  monitor: "M10 12h44v28H10z M24 48h16 M32 40v8",
  accesorio: "M32 8l6 12 13 2-9.5 9 2.2 13L32 38l-11.7 6 2.2-13-9.5-9 13-2z",
};
---

<div class:list={["relative overflow-hidden rounded-xl bg-white ring-1 ring-ink-100", className]}>
  {
    image ? (
      <img src={image} alt={title} class="h-full w-full object-contain p-3" loading="lazy" />
    ) : (
      <div class:list={["flex h-full w-full items-center justify-center bg-gradient-to-br", GRADIENTS[tier]]} role="img" aria-label={title}>
        <svg viewBox="0 0 64 64" class="h-1/2 w-1/2 text-white/90" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d={PATHS[type]} stroke-linejoin="round" stroke-linecap="round" />
        </svg>
      </div>
    )
  }
  <span class="absolute bottom-2 right-2 rounded-full bg-black/60 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-white">
    {TIER_LABELS[tier]}
  </span>
</div>
